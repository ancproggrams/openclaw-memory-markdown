{
  "id": "marq-memory",
  "kind": "memory",
  "name": "Marqs Memorie",
  "description": "Marqs Memorie: markdown-first memory plugin for OpenClaw with declarative, procedural, and maintenance memory layers.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "workspaceRoot": { "type": "string" },
      "memoryDir": { "type": "string" },
      "coreFiles": {
        "type": "array",
        "items": { "type": "string" }
      },
      "factsGlobs": {
        "type": "array",
        "items": { "type": "string" }
      },
      "includeDocs": { "type": "boolean" },
      "docsGlobs": {
        "type": "array",
        "items": { "type": "string" }
      },
      "maxFileBytes": { "type": "number", "minimum": 1024 },
      "autoRecall": { "type": "boolean" },
      "autoInjectMaxResults": { "type": "number", "minimum": 1, "maximum": 10 },
      "dailyWriteMode": {
        "type": "string",
        "enum": ["append-only"]
      },
      "archiveEnabled": { "type": "boolean" },
      "archiveSessionsDir": { "type": "string" },
      "archiveChunksDir": { "type": "string" },
      "archiveIndexesDir": { "type": "string" },
      "archiveEntityMapsDir": { "type": "string" },
      "archiveChunkMaxChars": { "type": "number", "minimum": 200 },
      "archiveChunkOverlapChars": { "type": "number", "minimum": 0 }
    }
  }
}
